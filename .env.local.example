# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ClickUp OAuth
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
CLICKUP_WEBHOOK_SECRET=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_VAULT_REPO=ViscapMedia/documentation
NEXT_PUBLIC_GITHUB_VAULT_REPO=ViscapMedia/documentation
# GitHub service token (PAT with repo scope) — used as fallback when a user hasn't connected GitHub
GITHUB_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=

# Internal API
VIDF_HOOK_API_KEY=

# Slack bot integration
SLACK_BOT_TOKEN=           # OAuth & Permissions → Bot User OAuth Token (xoxb-...)
SLACK_SIGNING_SECRET=      # Basic Information → App Credentials → Signing Secret
SLACK_ISSUES_CHANNEL_ID=   # Right-click support channel → View channel details → ID at bottom (C...)
SLACK_MICHAEL_USER_ID=     # Click your name → View full profile → ⋮ → Copy member ID (U...)
SLACK_WORKSPACE_URL=       # e.g. https://viscapvids.slack.com
SLACK_BOT_USER_ID=         # api.slack.com/apps → Basic Information → App Credentials → Bot User ID (U...)
SLACK_BOT_IMPROVEMENTS_CHANNEL_ID=  # Right-click #bot-improvements channel → View channel details → ID (C...)

# ClickUp bot integration
CLICKUP_BOT_TOKEN=             # Settings → Apps → API Token (pk_...)
CLICKUP_NEW_TICKETS_LIST_ID=   # List URL: app.clickup.com/.../v/li/<ID>
CLICKUP_KNOWN_ISSUES_LIST_ID=
CLICKUP_NEEDS_TUTORIAL_LIST_ID=
CLICKUP_PLANNING_LIST_ID=

# Comma-separated ClickUp status names that scaffold a design-index entry.
# Leave empty to keep the subsystem inert (safe dark ship).
CLICKUP_DESIGN_INDEX_STATUSES=
# GitHub repo for design-index PRs (owner/name). Defaults to kanon4us/pm-app.
GITHUB_REPO=
